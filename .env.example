# UPM Platform environment template. Copy to .env and adjust. NEVER commit real secrets.

# --- Control plane (Postgres in compose; SQLite default for local-without-docker) ---
UPM_DATABASE_URL=postgresql+psycopg://upm:upm@postgres:5432/upm

# --- Redis (Celery broker + query cache + load queue). Unset => single-process dev mode ---
UPM_REDIS_URL=redis://redis:6379/0

# --- Analytics plane (DuckDB) + Parquet landing zone ---
UPM_DUCKDB_PATH=/data/duckdb/analytics.duckdb
UPM_DUCKDB_LOAD_SPATIAL=0
UPM_LANDING_DIR=/data/landing
UPM_EXPORT_DIR=/data/exports

# --- Auth (CHANGE THESE) ---
UPM_JWT_SECRET=change-me-to-a-long-random-string-min-32-bytes
UPM_ACCESS_TTL_MIN=60
UPM_REFRESH_TTL_DAYS=7

# --- Read path / freshness ---
UPM_STALE_K=2.0
UPM_QUERY_CACHE_TTL_S=300

# --- Extraction source: synthetic (no Oracle) | oracle ---
UPM_SOURCE_TYPE=synthetic
UPM_ALLOWED_SOURCE_SCHEMAS=SON
# UPM_ORACLE_DSN=host:1521/SERVICE
# UPM_ORACLE_USER=upm_readonly
# UPM_ORACLE_PASSWORD=...

# --- AI proxy (Phase 5, optional) ---
# UPM_LLM_BASE_URL=http://vllm:8000/v1
# UPM_LLM_API_KEY=...
# UPM_LLM_MODEL=qwen3

# --- Web ---
UPM_CORS_ORIGINS=*

# --- Postgres container creds (used by compose) ---
POSTGRES_USER=upm
POSTGRES_PASSWORD=upm
POSTGRES_DB=upm
